rules_version = '2';

// OpenBuildOS workspace-project security rules.
//
// Membership source of truth lives on the top-level /projects/{pid} document:
//   { workspaceId: string, memberIds: string[], roles: { [uid]: viewer|editor|admin } }
// Workspace-level admins live on /workspaces/{wid}: { ownerId, adminIds }.
// Invites are bearer tokens under /workspaces/{wid}/invites/{inviteId} and are
// redeemed atomically (invite claim + members doc + project membership arrays
// in a single batch enforced via getAfter()).

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Shared helpers
    // ---------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isRealUser() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function uid() {
      return request.auth.uid;
    }

    // Stabilní federovaný subjekt napříč per-firma Firebase projekty.
    // Firebase přiděluje JINÉ request.auth.uid v každém projektu pro téhož
    // OIDC uživatele, takže membership/autorizace musí klíčovat federovaným
    // subjektem, ne uid. Pokud token nese identitu z provideru
    // 'oidc.openbuildos' (neprázdný list), vrátíme její první prvek; jinak
    // (dev e-mail/heslo, anonymous, … žádné identities) fallback na uid.
    // Pozn.: rules nemají snadné `in` na klíče mapy, proto čteme přes
    // .get('identities', {}).get('oidc.openbuildos', []) a kontrolujeme size().
    function principal() {
      return request.auth.token.firebase
          .get('identities', {})
          .get('oidc.openbuildos', []).size() > 0
        ? request.auth.token.firebase.identities['oidc.openbuildos'][0]
        : request.auth.uid;
    }

    function wsPath(wid) {
      return /databases/$(database)/documents/workspaces/$(wid);
    }

    function wsData(wid) {
      return get(wsPath(wid)).data;
    }

    function isWsOwner(wid) {
      return isRealUser()
        && exists(wsPath(wid))
        && wsData(wid).get('ownerId', '') == principal();
    }

    function isWsAdmin(wid) {
      return isRealUser()
        && exists(wsPath(wid))
        && (wsData(wid).get('ownerId', '') == principal()
            || principal() in wsData(wid).get('adminIds', []));
    }

    function projectPath(pid) {
      return /databases/$(database)/documents/projects/$(pid);
    }

    function projectData(pid) {
      return get(projectPath(pid)).data;
    }

    function projectInWorkspace(wid, pid) {
      return exists(projectPath(pid))
        && projectData(pid).get('workspaceId', '') == wid;
    }

    function projectRole(pid) {
      return projectData(pid).get('roles', {}).get(principal(), '');
    }

    function isProjectMember(wid, pid) {
      return isRealUser()
        && projectInWorkspace(wid, pid)
        && (principal() in projectData(pid).get('memberIds', [])
            || isWsAdmin(wid));
    }

    function canEditContent(wid, pid) {
      return isRealUser()
        && projectInWorkspace(wid, pid)
        && (projectRole(pid) in ['editor', 'admin'] || isWsAdmin(wid));
    }

    function canManageProject(wid, pid) {
      return isRealUser()
        && projectInWorkspace(wid, pid)
        && (projectRole(pid) == 'admin' || isWsAdmin(wid));
    }

    // Bootstrap-friendly variant: also lets admins create a project and its
    // members docs in one atomic batch. The post-state branch only applies
    // when the project doc did NOT exist before the batch -- in that case the
    // batched /projects create was itself validated (workspace admin with
    // roles[uid] == 'admin'). For pre-existing projects only the pre-state
    // role counts, so an invite redeem cannot escalate itself to admin.
    function canManageProjectAfter(wid, pid) {
      return canManageProject(wid, pid)
        || (isRealUser()
            && !exists(projectPath(pid))
            && getAfter(projectPath(pid)).data.get('workspaceId', '') == wid
            && getAfter(projectPath(pid)).data.get('roles', {}).get(principal(), '') == 'admin');
    }

    // ---------------------------------------------------------------------
    // Company / role model (per-project company assignment)
    //
    // A project doc may carry a `companies` map { [principal]: companyId }.
    // The `company_lead` role lets a member edit content authored by other
    // members of the SAME company on that project (in addition to their own).
    // ---------------------------------------------------------------------

    // The company a given member is assigned to on a project (or '' if none).
    function memberCompany(pid, who) {
      return projectData(pid).get('companies', {}).get(who, '');
    }

    function isSameProjectCompany(wid, pid, companyId) {
      return companyId != ''
        && isProjectMember(wid, pid)
        && memberCompany(pid, principal()) == companyId;
    }

    function isCompanySpaceLead(wid, pid, companyId) {
      return isSameProjectCompany(wid, pid, companyId)
        && projectRole(pid) in ['company_lead', 'editor', 'admin'];
    }

    function hasCompanyResourceAccess(wid, pid, companyId, data) {
      return isSameProjectCompany(wid, pid, companyId)
        && (
          isCompanySpaceLead(wid, pid, companyId)
          || data.get('accessMode', '') == 'company_all'
          || (data.get('accessMode', '') == 'restricted'
              && principal() in data.get('allowedPrincipalIds', []))
        );
    }

    function validCompanyResourceIdentity(companyId, data) {
      return data.get('scope', '') == 'company_internal'
        && data.get('ownerCompanyId', '') == companyId
        && data.get('createdBy', '') == principal()
        && data.get('accessMode', '') in ['company_all', 'restricted']
        && data.get('allowedPrincipalIds', []) is list;
    }

    function companyFolderPath(wid, pid, companyId, folderId) {
      return /databases/$(database)/documents/workspaces/$(wid)/projects/$(pid)/companySpaces/$(companyId)/folders/$(folderId);
    }

    function companyPlanPath(wid, pid, companyId, planId) {
      return /databases/$(database)/documents/workspaces/$(wid)/projects/$(pid)/companySpaces/$(companyId)/plans/$(planId);
    }

    function canUseCompanyPlan(wid, pid, companyId, planId, data) {
      return planId != ''
        && exists(companyPlanPath(wid, pid, companyId, planId))
        && hasCompanyResourceAccess(wid, pid, companyId, get(companyPlanPath(wid, pid, companyId, planId)).data)
        && data.get('folderId', '') == get(companyPlanPath(wid, pid, companyId, planId)).data.get('folderId', '')
        && data.get('accessMode', '') == get(companyPlanPath(wid, pid, companyId, planId)).data.get('accessMode', '')
        && data.get('allowedPrincipalIds', []) == get(companyPlanPath(wid, pid, companyId, planId)).data.get('allowedPrincipalIds', []);
    }

    function canUseCompanyFolder(wid, pid, companyId, folderId, data) {
      return (
          folderId == ''
          && data.get('accessMode', '') == 'company_all'
          && data.get('allowedPrincipalIds', []).size() == 0
        ) || (
          folderId != ''
          && exists(companyFolderPath(wid, pid, companyId, folderId))
          && hasCompanyResourceAccess(wid, pid, companyId, get(companyFolderPath(wid, pid, companyId, folderId)).data)
          && data.get('accessMode', '') == get(companyFolderPath(wid, pid, companyId, folderId)).data.get('accessMode', '')
          && data.get('allowedPrincipalIds', []) == get(companyFolderPath(wid, pid, companyId, folderId)).data.get('allowedPrincipalIds', [])
        );
    }

    function validChildCompanyAccess(wid, pid, companyId, parentId, data) {
      return (
          parentId == ''
          && data.get('accessMode', '') in ['company_all', 'restricted']
        ) || (
          parentId != ''
          && exists(companyFolderPath(wid, pid, companyId, parentId))
          && hasCompanyResourceAccess(wid, pid, companyId, get(companyFolderPath(wid, pid, companyId, parentId)).data)
          && (
            get(companyFolderPath(wid, pid, companyId, parentId)).data.get('accessMode', '') == 'company_all'
            || (
              data.get('accessMode', '') == 'restricted'
              && get(companyFolderPath(wid, pid, companyId, parentId)).data.get('allowedPrincipalIds', []).hasAll(data.get('allowedPrincipalIds', []))
            )
          )
        );
    }

    // Content is authored by the caller (createdBy == principal).
    function authoredBySelf() {
      return resource.data.get('createdBy', '') == principal();
    }

    // May modify (update/delete) an existing user-generated content doc.
    function canModifyContent(wid, pid) {
      return isProjectMember(wid, pid) && (
        projectRole(pid) in ['editor', 'admin'] || isWsAdmin(wid)
        || authoredBySelf()
        || (projectRole(pid) == 'company_lead'
            && memberCompany(pid, principal()) != ''
            && memberCompany(pid, resource.data.get('createdBy', '')) == memberCompany(pid, principal()))
      );
    }

    // May create a user-generated content doc. Author (createdBy) musí být buď
    // PRÁZDNÝ (obsah ještě nezadrátovaný na authorship → editovatelný jen
    // editor/admin, bezpečné), nebo SÁM volající (principal) — nikdy NĚKDO JINÝ
    // (zákaz spoofingu autorství). Tím se žádný create nerozbije, i kdyby daná
    // kolekce createdBy nestampovala.
    function canCreateContent(wid, pid) {
      return isProjectMember(wid, pid)
        && (request.resource.data.get('createdBy', '') == ''
            || request.resource.data.get('createdBy', '') == principal());
    }

    // Member designated as a document approver on this project (admin / workspace
    // admin always count; others need `canApprove == true` on their member doc).
    // Gate for review decisions on document versions (approve/reject/issue) — WP1.
    function isApprover(wid, pid) {
      return isProjectMember(wid, pid)
        && (projectRole(pid) == 'admin'
            || isWsAdmin(wid)
            || get(/databases/$(database)/documents/workspaces/$(wid)/projects/$(pid)/members/$(principal()))
                 .data.get('canApprove', false) == true);
    }

    // ---------------------------------------------------------------------
    // Workspaces
    // ---------------------------------------------------------------------

    match /workspaces/{wid} {
      // The id is not secret; the doc only carries owner/admin metadata.
      allow get: if isRealUser();
      allow list: if false;
      // Bootstrap claim: first creator becomes owner (keyed by principal).
      allow create: if isRealUser()
        && request.resource.data.ownerId == principal()
        && request.resource.data.adminIds is list;
      // Owner can manage admins/name but never transfer/drop ownership here.
      allow update: if isRealUser()
        && resource.data.get('ownerId', '') == principal()
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Companies (firm-level company directory)
    //
    // Any real user (firm member) may read the company list; only workspace
    // admins manage entries.
    // ---------------------------------------------------------------------

    match /workspaces/{wid}/companies/{companyId} {
      allow read: if isRealUser();
      allow create, update, delete: if isWsAdmin(wid);
    }

    // ---------------------------------------------------------------------
    // Firm member directory (workspace-level, keyed by principal)
    //
    // Any real user (firm member) may read the directory; workspace admins
    // manage entries, and a user may upsert ONLY their own entry (e.g. on
    // invite redeem to record their displayName/companyId).
    // ---------------------------------------------------------------------

    match /workspaces/{wid}/members/{memberPrincipal} {
      allow read: if isRealUser();
      allow create, update: if isWsAdmin(wid) || principal() == memberPrincipal;
      allow delete: if isWsAdmin(wid);
    }

    // ---------------------------------------------------------------------
    // Invites (bearer token documents)
    // ---------------------------------------------------------------------

    function invitePath(wid, inviteId) {
      return /databases/$(database)/documents/workspaces/$(wid)/invites/$(inviteId);
    }

    // The members/{uid} self-join create is only valid when the same batch
    // claims the referenced invite (getAfter forces atomicity).
    function redeemOk(wid, pid, inviteId, role) {
      return get(invitePath(wid, inviteId)).data.projectId == pid
        && get(invitePath(wid, inviteId)).data.usedBy == null
        && request.time < get(invitePath(wid, inviteId)).data.expiresAt
        && role == get(invitePath(wid, inviteId)).data.role
        // Only APPROVED invites are redeemable. Missing field == approved
        // (backward compat with pre-#367 invites).
        && get(invitePath(wid, inviteId)).data.get('approvalStatus', 'approved') == 'approved'
        && getAfter(invitePath(wid, inviteId)).data.usedBy == principal();
    }

    // A company lead on the project (company_lead/editor, NOT an admin) may
    // PROPOSE an invite; it stays pending_approval until a project admin/ws admin
    // approves it (issue #367). Direct admins/ws admins bypass approval.
    function canProposeInvite(wid, pid) {
      return isRealUser()
        && projectInWorkspace(wid, pid)
        && projectRole(pid) in ['company_lead', 'editor'];
    }

    match /workspaces/{wid}/invites/{inviteId} {
      // The invite id itself is the secret; any real user holding it may read.
      allow get: if isRealUser();
      allow list: if isWsAdmin(wid);
      allow create: if isRealUser()
        && request.resource.data.role in ['viewer', 'editor']
        && request.resource.data.usedBy == null
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.createdBy == principal()
        && (
            // Direct: project admin / workspace admin issues a live invite.
            (canManageProject(wid, request.resource.data.projectId)
              && request.resource.data.get('approvalStatus', 'approved') == 'approved')
            // Manager/company lead proposes an invite needing admin approval.
            || (canProposeInvite(wid, request.resource.data.projectId)
              && request.resource.data.approvalStatus == 'pending_approval')
        );
      allow update: if (
          // Redeem: only claiming an unused, unexpired, APPROVED invite for yourself.
          isRealUser()
          && resource.data.usedBy == null
          && resource.data.get('approvalStatus', 'approved') == 'approved'
          && request.time < resource.data.expiresAt
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['usedBy', 'usedAt'])
          && request.resource.data.usedBy == principal()
        )
        // Approve/reject + revoke: project admin / ws admin may edit the invite
        // (this also covers flipping approvalStatus pending_approval -> approved).
        || canManageProject(wid, resource.data.projectId);
      allow delete: if canManageProject(wid, resource.data.projectId);
    }

    // ---------------------------------------------------------------------
    // Project members mirror (UI metadata; rules read /projects instead)
    // ---------------------------------------------------------------------

    match /workspaces/{wid}/projects/{pid}/members/{memberUid} {
      allow get, list: if isProjectMember(wid, pid);
      allow create: if (
          // Self-join via invite redeemed in the same batch.
          // members/{id} doc is keyed by principal (federated subject or uid).
          isRealUser()
          && memberUid == principal()
          && request.resource.data.keys()
              .hasOnly(['role', 'displayName', 'email', 'inviteId', 'joinedAt', 'companyId'])
          && request.resource.data.role in ['viewer', 'editor']
          && redeemOk(wid, pid, request.resource.data.inviteId,
              request.resource.data.role)
        ) || (
          canManageProjectAfter(wid, pid)
          && request.resource.data.role in ['viewer', 'editor', 'admin', 'company_editor']
        );
      allow update: if canManageProjectAfter(wid, pid)
        && request.resource.data.role in ['viewer', 'editor', 'admin', 'company_editor'];
      allow delete: if canManageProject(wid, pid);
    }

    // Firemní interní pracovní prostory jsou oddělené od oficiálních kolekcí,
    // aby legacy list query nikdy nemíchaly obsah s rozdílnou viditelností.
    match /workspaces/{wid}/projects/{pid}/companySpaces/{companyId} {
      allow get: if isSameProjectCompany(wid, pid, companyId);
      allow list: if false;
      allow create: if (isSameProjectCompany(wid, pid, companyId) || canManageProject(wid, pid))
        && request.resource.data.get('companyId', '') == companyId
        && request.resource.data.get('projectId', '') == pid
        && request.resource.data.get('workspaceId', '') == wid
        && request.resource.data.get('scope', '') == 'company_internal'
        && request.resource.data.get('createdBy', '') == principal();
      allow update: if isCompanySpaceLead(wid, pid, companyId)
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.scope == resource.data.scope;
      allow delete: if false;

      match /folders/{folderId} {
        allow get, list: if hasCompanyResourceAccess(wid, pid, companyId, resource.data);
        allow create: if isCompanySpaceLead(wid, pid, companyId)
          && validCompanyResourceIdentity(companyId, request.resource.data)
          && request.resource.data.get('folderId', '') == folderId
          && request.resource.data.get('parentId', '') != folderId
          && validChildCompanyAccess(wid, pid, companyId, request.resource.data.get('parentId', ''), request.resource.data);
        allow update: if isCompanySpaceLead(wid, pid, companyId)
          && request.resource.data.get('scope', '') == resource.data.get('scope', '')
          && request.resource.data.get('ownerCompanyId', '') == resource.data.get('ownerCompanyId', '')
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && request.resource.data.get('folderId', '') == resource.data.get('folderId', '')
          && request.resource.data.get('parentId', '') != folderId
          && validChildCompanyAccess(wid, pid, companyId, request.resource.data.get('parentId', ''), request.resource.data);
        allow delete: if isCompanySpaceLead(wid, pid, companyId);
      }

      match /documents/{documentId} {
        allow get, list: if hasCompanyResourceAccess(wid, pid, companyId, resource.data);
        allow create: if validCompanyResourceIdentity(companyId, request.resource.data)
          && isSameProjectCompany(wid, pid, companyId)
          && request.resource.data.get('documentId', '') == documentId
          && request.resource.data.get('approvalMode', '') == 'none'
          && canUseCompanyFolder(wid, pid, companyId, request.resource.data.get('folderId', ''), request.resource.data);
        allow update: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && (resource.data.get('createdBy', '') == principal() || isCompanySpaceLead(wid, pid, companyId))
          && request.resource.data.get('scope', '') == resource.data.get('scope', '')
          && request.resource.data.get('ownerCompanyId', '') == resource.data.get('ownerCompanyId', '')
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && request.resource.data.get('approvalMode', '') == 'none'
          && canUseCompanyFolder(wid, pid, companyId, request.resource.data.get('folderId', ''), request.resource.data);
        allow delete: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && (resource.data.get('createdBy', '') == principal() || isCompanySpaceLead(wid, pid, companyId));
      }

      match /documentVersions/{versionId} {
        allow get, list: if hasCompanyResourceAccess(wid, pid, companyId, resource.data);
        allow create: if validCompanyResourceIdentity(companyId, request.resource.data)
          && isSameProjectCompany(wid, pid, companyId)
          && request.resource.data.get('versionId', '') == versionId
          && request.resource.data.get('status', '') == 'working'
          && request.resource.data.get('workflowMode', '') == 'none'
          && canUseCompanyFolder(wid, pid, companyId, request.resource.data.get('folderId', ''), request.resource.data);
        allow update: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && (resource.data.get('createdBy', '') == principal() || isCompanySpaceLead(wid, pid, companyId))
          && request.resource.data.get('scope', '') == resource.data.get('scope', '')
          && request.resource.data.get('ownerCompanyId', '') == resource.data.get('ownerCompanyId', '')
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && canUseCompanyFolder(wid, pid, companyId, request.resource.data.get('folderId', ''), request.resource.data);
        allow delete: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && (resource.data.get('createdBy', '') == principal() || isCompanySpaceLead(wid, pid, companyId));
      }

      match /plans/{planId} {
        allow get, list: if hasCompanyResourceAccess(wid, pid, companyId, resource.data);
        allow create: if validCompanyResourceIdentity(companyId, request.resource.data)
          && isSameProjectCompany(wid, pid, companyId)
          && request.resource.data.get('planId', '') == planId
          && canUseCompanyFolder(wid, pid, companyId, request.resource.data.get('folderId', ''), request.resource.data);
        allow update: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && (resource.data.get('createdBy', '') == principal() || isCompanySpaceLead(wid, pid, companyId))
          && request.resource.data.get('scope', '') == resource.data.get('scope', '')
          && request.resource.data.get('ownerCompanyId', '') == resource.data.get('ownerCompanyId', '')
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && canUseCompanyFolder(wid, pid, companyId, request.resource.data.get('folderId', ''), request.resource.data);
        allow delete: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && (resource.data.get('createdBy', '') == principal() || isCompanySpaceLead(wid, pid, companyId));
      }

      // Sdílené firemní markupy jednoho planVersion. Task piny sem nepatří a
      // zůstávají v betě zakázané; dokument obsahuje pouze geometrické anotace.
      // Pozn.: rules neumí iterovat prvky listu, takže per-item typ nevaliduje —
      // task piny jsou v appce samostatné Tasky (ne anotace), FE je do `items`
      // nikdy nezapisuje a nad firemním plánem je i vytvoření pinu vypnuté.
      // Zde vynucujeme aspoň strop velikosti pole proti zneužití zápisem.
      match /planAnnotationSets/{versionId} {
        allow get: if hasCompanyResourceAccess(wid, pid, companyId, resource.data);
        allow list: if isCompanySpaceLead(wid, pid, companyId);
        allow create: if isSameProjectCompany(wid, pid, companyId)
          && validCompanyResourceIdentity(companyId, request.resource.data)
          && request.resource.data.get('planVersionId', '') == versionId
          && request.resource.data.get('items', []) is list
          && request.resource.data.get('items', []).size() <= 2000
          && canUseCompanyPlan(wid, pid, companyId, request.resource.data.get('planId', ''), request.resource.data);
        allow update: if hasCompanyResourceAccess(wid, pid, companyId, resource.data)
          && request.resource.data.get('scope', '') == resource.data.get('scope', '')
          && request.resource.data.get('ownerCompanyId', '') == resource.data.get('ownerCompanyId', '')
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && request.resource.data.get('planId', '') == resource.data.get('planId', '')
          && request.resource.data.get('planVersionId', '') == resource.data.get('planVersionId', '')
          && request.resource.data.get('items', []) is list
          && request.resource.data.get('items', []).size() <= 2000
          && canUseCompanyPlan(wid, pid, companyId, request.resource.data.get('planId', ''), request.resource.data);
        allow delete: if false;
      }
    }

    // ---------------------------------------------------------------------
    // Notification queue (recipient-scoped reads)
    // ---------------------------------------------------------------------

    match /workspaces/{wid}/projects/{pid}/notificationQueue/{notificationId} {
      allow create: if isProjectMember(wid, pid)
        && request.resource.data.workspaceId == wid
        && request.resource.data.projectId == pid
        && request.resource.data.recipientIds is list;
      // Provable for queries shaped
      // where('recipientIds', 'array-contains', currentPrincipal).
      allow get, list: if isRealUser()
        && principal() in resource.data.recipientIds;
      // Recipients may only append themselves to readBy.
      allow update: if isRealUser()
        && principal() in resource.data.recipientIds
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readBy'])
        && request.resource.data.readBy.hasAll(resource.data.get('readBy', []))
        && principal() in request.resource.data.readBy;
      allow delete: if canManageProject(wid, pid);
    }

    // ---------------------------------------------------------------------
    // Project content collections (explicit enumeration -- no catch-all so
    // members/notificationQueue/invites can never be reached through these).
    // ---------------------------------------------------------------------

    // Task status-transition guard (issue #367, docs/TASK_WORKFLOW_USER_STORIES).
    // 'completed' = Koordinátor+ nebo autor (OQ-4); 'verified' = Schvalovatel
    // (admin/firma nebo flag canApprove, OQ-5); vrátit verified = Koordinátor+
    // (OQ-6a). Enforcuje se JEN na změně statusu; nezměněný status projde komukoli,
    // kdo smí obsah upravit (editace jiných polí u hotového úkolu se nerozbije).
    function canCompleteTask(wid, pid) {
      return projectRole(pid) in ['company_lead', 'editor', 'admin'] || isWsAdmin(wid);
    }
    // Autor úkolu (createdBy == principal). Funguje pro create i update — createdBy
    // je u update immutable, takže request.resource nese autora v obou případech.
    function taskAuthoredBySelf() {
      return request.resource.data.get('createdBy', '') == principal();
    }
    // Kdo smí dostat úkol DO „hotovo" stavu (issue #367, viz TASK_WORKFLOW_USER_STORIES):
    //  - 'verified'  = Schvalovatel (Správce projektu/firmy NEBO flag canApprove) — OQ-5
    //  - 'completed' = Koordinátor+ NEBO autor vlastního úkolu — OQ-4
    function canReachDoneStatus(wid, pid, status) {
      return status == 'verified' ? isApprover(wid, pid)
        : status == 'completed' ? (canCompleteTask(wid, pid) || taskAuthoredBySelf())
        : true;
    }
    // Návrat ZPĚT z „hotovo" stavu (reopen). Dopředný postup completed→verified NENÍ
    // reopen (řeší ho jen canReachDoneStatus = isApprover), proto se sem nepočítá.
    //  - z 'verified'  = Koordinátor+ (vrací nalezenou vadu; nemusí být admin) — OQ-6a
    //  - z 'completed' do práce = Koordinátor+ NEBO autor — OQ-6c
    function reopenOk(wid, pid, oldStatus, newStatus) {
      return oldStatus == 'verified' ? canCompleteTask(wid, pid)
        : (oldStatus == 'completed' && newStatus != 'verified')
            ? (canCompleteTask(wid, pid) || taskAuthoredBySelf())
        : true;
    }
    // Přechod je OK, když se status NEMĚNÍ, nebo když volající smí CÍLOVÝ dosáhnout
    // A (jde-li o návrat z hotovo) smí i reopen. verified nastaví Schvalovatel,
    // vrací Koordinátor+.
    function taskStatusTransitionOk(wid, pid) {
      return request.resource.data.get('status', '') == resource.data.get('status', '')
        || (canReachDoneStatus(wid, pid, request.resource.data.get('status', ''))
            && reopenOk(wid, pid, resource.data.get('status', ''), request.resource.data.get('status', '')));
    }

    match /workspaces/{wid}/projects/{pid}/tasks/{docId} {
      allow read: if isProjectMember(wid, pid);
      // Nový úkol nesmí rovnou vzniknout jako completed/verified bez příslušné role
      // (jinak by šel guard na update obejít vytvořením už-hotového úkolu).
      allow create: if canCreateContent(wid, pid)
        && canReachDoneStatus(wid, pid, request.resource.data.get('status', ''));
      allow update: if canModifyContent(wid, pid)
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')  // author immutable
        && taskStatusTransitionOk(wid, pid);
      allow delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/files/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      allow update: if canModifyContent(wid, pid)
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '');  // author immutable
      allow delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/photos/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      allow update: if canModifyContent(wid, pid)
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '');  // author immutable
      allow delete: if canModifyContent(wid, pid);
    }

    // Připnutí fotky do kontextu (task/plán) + anotace té varianty. Fotka samotná
    // zůstává jeden záznam v /photos; pin ji jen referencuje (photoId).
    match /workspaces/{wid}/projects/{pid}/photoPins/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      allow update: if canModifyContent(wid, pid)
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '');  // author immutable
      allow delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/diaryEntries/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      allow update: if canModifyContent(wid, pid)
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '');  // author immutable
      allow delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/plans/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create, update, delete: if canEditContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/planAnnotations/{docId} {
      // Soukromý markup (isPrivate) vidí JEN jeho autor (ownerPrincipal == principal);
      // veřejné vidí každý člen. Klient čte dvěma dotazy (veřejné + vlastní soukromé).
      allow read: if isProjectMember(wid, pid)
        && (resource.data.get('isPrivate', false) == false
            || resource.data.get('ownerPrincipal', '') == principal());
      allow create, update, delete: if canEditContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/documents/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      // Author immutable. Editovat smí běžná práva k obsahu; schvalovatel navíc
      // smí jako vedlejší efekt approve transakce přepnout jen platnou revizi
      // (currentVersionId/updatedAt) — i když není editor/autor dokumentu (WP1).
      allow update: if request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
        && (
          canModifyContent(wid, pid)
          || (isApprover(wid, pid)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentVersionId', 'updatedAt']))
        );
      allow delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/documentVersions/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      // Schvalovatel (isApprover) smí verzi aktualizovat plně — zapsat svoje
      // rozhodnutí do `approvals` mapy, odvozený status i supersede (i když u
      // policy „all" status zatím zůstává under_review). Ostatní (uploader/
      // editor/autor) smí běžné editace, ale NE přechod do rozhodnutí (zákaz
      // self-approve). Audit se v rules nevynucuje.
      allow update: if request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')  // author immutable
        && (
          isApprover(wid, pid)
          || (canModifyContent(wid, pid)
              && !(request.resource.data.status != resource.data.status
                   && request.resource.data.status in ['approved', 'approved_with_comments', 'rejected', 'superseded', 'for_construction']))
        );
      allow delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/documentComments/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      allow update: if canModifyContent(wid, pid)
        && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '');  // author immutable
      allow delete: if canModifyContent(wid, pid);
    }

    // Registr složek projektu (Fáze 1, bez per-složkových práv). Člen smí číst
    // a zakládat složky; mazat/měnit editor/admin/autor (canModifyContent).
    match /workspaces/{wid}/projects/{pid}/folders/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create: if canCreateContent(wid, pid);
      allow update, delete: if canModifyContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/transmittals/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create, update, delete: if canEditContent(wid, pid);
    }

    match /workspaces/{wid}/projects/{pid}/documentEvents/{docId} {
      allow read: if isProjectMember(wid, pid);
      allow create, update, delete: if canEditContent(wid, pid);
    }

    // ---------------------------------------------------------------------
    // Share links (bearer token documents -- public read-out of a single item)
    //
    // The token (doc id) is the secret, so `get` is public: an unauthenticated
    // recipient holding the link reads exactly that one record (title + a
    // already-public file URL -- never sensitive metadata). Listing requires
    // membership (managing share links), and only editors+ may create/revoke.
    // ---------------------------------------------------------------------

    match /workspaces/{wid}/projects/{pid}/shareLinks/{token} {
      allow get: if true;
      allow list: if isProjectMember(wid, pid);
      allow create, update, delete: if canEditContent(wid, pid);
    }

    // ---------------------------------------------------------------------
    // Document status pointer (#371 — verifikace revize přes QR)
    //
    // Public pointer to a document's CURRENT version so the anonymous
    // verification page (/share/:wid/:token) can tell whether the scanned
    // revision is current or superseded. Carries ONLY harmless data
    // (currentVersionId + label) -- never titles, URLs or member info.
    // Written best-effort by upload (editors) and approval (approvers may
    // lack edit rights, hence the isApprover branch).
    // ---------------------------------------------------------------------

    function validDocumentStatus(data) {
      // Veřejně čitelný doc — schema guard: JEN neškodná pole, žádné volné klíče.
      return data.keys().hasOnly(['currentVersionId', 'currentVersionLabel', 'updatedAt'])
        && data.currentVersionId is string && data.currentVersionId.size() > 0
        && data.currentVersionLabel is string;
    }

    match /workspaces/{wid}/projects/{pid}/documentStatus/{documentId} {
      allow get: if true;
      allow list: if isProjectMember(wid, pid);
      allow create, update: if (canEditContent(wid, pid) || isApprover(wid, pid))
        && validDocumentStatus(request.resource.data);
      allow delete: if canEditContent(wid, pid);
    }

    // ---------------------------------------------------------------------
    // Top-level projects (source of truth for membership)
    // ---------------------------------------------------------------------

    // Invite self-join on the project doc: only adds the caller to
    // memberIds/roles, with the role copied from the members doc created in
    // the same batch (which itself requires a valid invite claim).
    function inviteSelfJoin(pid) {
      return isRealUser()
        && !(principal() in resource.data.get('memberIds', []))
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberIds', 'roles', 'updatedAt', 'companies'])
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.hasAll(resource.data.get('memberIds', []))
        && request.resource.data.memberIds.size()
            == resource.data.get('memberIds', []).size() + 1
        && principal() in request.resource.data.memberIds
        && request.resource.data.roles.diff(resource.data.get('roles', {}))
            .affectedKeys().hasOnly([principal()])
        && request.resource.data.roles[principal()]
            == getAfter(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)/projects/$(pid)/members/$(principal())).data.role;
    }

    match /projects/{pid} {
      // Direct field access keeps the rule provable for both query shapes:
      // where('memberIds','array-contains', principal) and
      // where('workspaceId','==', wid) issued by workspace admins.
      allow get, list: if isRealUser()
        && (principal() in resource.data.memberIds
            || isWsAdmin(resource.data.workspaceId));
      allow create: if isRealUser()
        && isWsAdmin(request.resource.data.workspaceId)
        && principal() in request.resource.data.memberIds
        && request.resource.data.roles.get(principal(), '') == 'admin';
      // Workspace owner/admin: full project doc control incl. membership.
      // Project admin: may edit project content but MUST NOT touch
      // memberIds/roles (membership changes only via wsAdmin or invite flow),
      // preventing one admin from demoting/removing other admins or the owner.
      allow update: if (
          isRealUser()
          && isWsAdmin(resource.data.get('workspaceId', ''))
          && request.resource.data.workspaceId == resource.data.workspaceId
        ) || (
          isRealUser()
          && resource.data.get('roles', {}).get(principal(), '') == 'admin'
          && request.resource.data.workspaceId == resource.data.workspaceId
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['memberIds', 'roles'])
        ) || inviteSelfJoin(pid);
      allow delete: if isRealUser()
        && (resource.data.get('roles', {}).get(principal(), '') == 'admin'
            || isWsAdmin(resource.data.get('workspaceId', '')));
    }

    // Immutable per-project audit log.
    match /projects/{pid}/task_audit/{entryId} {
      allow read: if isProjectMember(projectData(pid).get('workspaceId', ''), pid);
      allow create: if canEditContent(projectData(pid).get('workspaceId', ''), pid);
      allow update, delete: if false;
    }

    // Legacy annotation blobs -- superseded by
    // workspaces/{wid}/projects/{pid}/planAnnotations.
    match /plan_annotations/{docId} {
      allow read, write: if false;
    }

    // User registry (workspace connections) — used when this project also
    // serves as the central/login project (single-project deployment).
    // Owner-only: each user reads/writes only their own registry doc.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------
    // Pending invites registry (CENTRÁLNÍ projekt openbuildos)
    //
    // Mirror firemní pozvánky, aby ji pozvaný NAŠEL po přihlášení i bez linku
    // (firemní invite žije jen ve workspaces/{wid}/invites/{token}, kam nemá
    // přístup). Doc id = token = bearer tajemství (náhodný UUID).
    //
    // Čte JEN adresát (match jeho ověřeného e-mailu), publikuje libovolný reálný
    // uživatel (zvoucí admin firmy), status flipne JEN adresát. Pole nesou
    // veřejné klientské identifikátory firmy (apiKey ap.) pro sestavení
    // WorkspaceConnection při přijetí — nic tajného.
    // Query příjemce: where('inviteeEmail','==', mojeEmail) & where('status','==','pending').
    // ---------------------------------------------------------------------
    match /pendingInvites/{token} {
      allow get, list: if isRealUser()
        && resource.data.get('inviteeEmail', '') == request.auth.token.get('email', '');
      allow create: if isRealUser()
        && request.resource.data.get('status', '') == 'pending'
        && request.resource.data.get('inviteeEmail', '') is string
        && request.resource.data.get('inviteeEmail', '') != ''
        && request.resource.data.get('role', '') in ['viewer', 'editor'];
      // Adresát smí jen překlopit status (přijmout/odmítnout), nic jiného.
      allow update: if isRealUser()
        && resource.data.get('inviteeEmail', '') == request.auth.token.get('email', '')
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'resolvedAt'])
        && request.resource.data.status in ['accepted', 'declined'];
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Veřejná konfigurace firmy (federační URL pro auto-discovery)
    //
    // `config/public` = { authExchangeUrl }. Zapisuje setup CLI (admin SDK /
    // REST s tokenem vlastníka, mimo rules). Čte se VEŘEJNĚ (i bez přihlášení),
    // aby si appka při připojení firmy doplnila URL token-exchange funkce sama —
    // bez ručního opisování z výstupu CLI. URL endpointu NENÍ tajná (autorizaci
    // dělá samotná funkce ověřením centrálního ID tokenu).
    // ---------------------------------------------------------------------
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // No catch-all: everything else is denied by default.
  }
}
