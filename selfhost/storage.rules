rules_version = '2';

// Firemní úložiště souborů (per-firma Firebase projekt).
//
// POZOR — DESIGN ROZHODNUTÍ (22. 6. 2026): původní verze gateovala write per
// projekt přes cross-service `firestore.get()` (kontrola memberIds/roles/ownerId
// v Firestore). To se v praxi ukázalo jako NESPOLEHLIVÉ — Storage vracel 403
// (storage/unauthorized) i pro VLASTNÍKA, který má v projektu roli 'admin' a je
// ownerId workspace. Cross-service get ve Storage rules je dlouhodobě vrtkavý.
//
// Proto držíme JEDNODUCHÝ a SPOLEHLIVÝ gate: čte/píše každý PŘIHLÁŠENÝ uživatel
// FIRMY (přihlášení do firemního backendu probíhá token-exchangem, takže to je
// vždy člen firmy — cizí firma má vlastní projekt s vlastními rules).
//
// Granularita per-PROJEKT je vynucená na úrovni FIRESTORE METADAT: každý
// foto/dokument/plán má v Firestore svůj doc s member rules. Bez přístupu k tomu
// docu uživatel ani neobjeví cestu objektu ve Storage (cesty jsou UUID).
//
// TODO (až bude potřeba tvrdší izolace mezi projekty jedné firmy): vrátit
// per-projekt přes spolehlivý mechanismus — custom claims se seznamem projektů
// v token-exchange tokenu, nebo ověřený fungující cross-service get.

service firebase.storage {
  match /b/{bucket}/o {

    function isRealUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Přímý Firebase download/upload interních firemních objektů je zakázaný.
    // Autorizaci i resumable upload zajišťuje companion Function `companyFile`.
    match /workspaces/{wid}/projects/{pid}/companySpaces/{companyId}/{rest=**} {
      allow read, write: if false;
    }

    // Projektové soubory firmy. Kategorie `companySpaces` je vyňatá, aby širší
    // pravidlo nemohlo přebít bezpečnou Function bránu výše (allow se mezi
    // souběžnými match bloky skládá pomocí OR).
    match /workspaces/{wid}/projects/{pid}/{category}/{rest=**} {
      allow write: if category != 'companySpaces'
        && isRealUser()
        && (request.resource == null || request.resource.size < 200 * 1024 * 1024);
      allow read: if category != 'companySpaces' && isRealUser();
    }

    // Připojovací probe a případné neprojektové objekty workspace.
    match /workspaces/{wid}/{objectName} {
      allow read: if isRealUser();
      allow write: if isRealUser()
        && (request.resource == null || request.resource.size < 200 * 1024 * 1024);
    }
    match /workspaces/{wid}/{category}/{rest=**} {
      allow read: if category != 'projects' && isRealUser();
      allow write: if category != 'projects'
        && isRealUser()
        && (request.resource == null || request.resource.size < 200 * 1024 * 1024);
    }

    // Vše ostatní (vč. legacy /projects/**) je zakázané.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
